# quicksetup defaults

QUICKSETUP_REPO_URL="https://github.com/sreayan/quicksetup.git"
QUICKSETUP_INSTALL_ROOT="$HOME/.local/share/quicksetup"

ENABLE_BASICS=1
ENABLE_CPP=1
ENABLE_RUST=1
ENABLE_GO=1
ENABLE_PYTHON=1
ENABLE_NODE=1
ENABLE_EDITORS=1
ENABLE_SHELL=1
ENABLE_DOCKER=1
ENABLE_DOTFILES=1

PREFERRED_SHELL="zsh"
INSTALL_NEOVIM=1
INSTALL_VSCODE=1
INSTALL_DOCKER=1
